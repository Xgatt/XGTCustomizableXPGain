// ---- Error strings ----
@1000 = ~XGT Customizable XP Gain requires BG:EE, BG2:EE, or EET.~
@1001 = ~XGT Customizable XP Gain requires EEex. Install EEex first: https://github.com/Bubb13/EEex~

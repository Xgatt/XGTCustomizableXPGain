// XGT Customizable XP Gain, American English

// ---- Component name ----
@1 = ~Enable configurable dynamic XP gain~

// ---- Portrait-icon / effect-list labels ----
@50 = ~Learning faster~
@51 = ~Learning slower~

// ---- Item strings ----
@10 = ~Tome of the Masterful Learner~
@11 = ~Tome of the Masterful Learner

This unassuming tome promises its reader mastery over the process of learning itself. By employing the techniques contained within, one can slow down or accelerate the process of learning itself.~
@12 = ~Study~

// ---- Root dialogue ----
@100 = ~To what end do you Study?~
@101 = ~I seek to learn faster (increase XP gain).~
@102 = ~I seek to slow my learning (decrease XP gain).~
@103 = ~I will learn at a steady pace (reset to default XP gain).~
@104 = ~I wish to know how fast my team is learning.~
@105 = ~Nevermind. Put the book away.~

// ---- Sub-dialogue ----
@110 = ~By how much?~
@111 = ~On second thought...~

// ---- Increase percentages (+5%, +10%, +15%, +20%, +25%, +50%, +75%, +100%, +150%, +200%, +300%, +400%, +500%) ----
